---
import '../styles/global.css';
const base = import.meta.env.BASE_URL;
const basePrefix = base.endsWith('/') ? base : base + '/';
const href = (path = '') => basePrefix + String(path).replace(/^\/+/, '');
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || "G-QWP2XJ4VMK";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Media</title>
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline set:html={`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${gaId}');`}></script>
      </>
    )}

  </head>
  <body>
    <main class="container">
      <h1>Media</h1>
      <p>
        Placeholder for photos, audio clips, and videos.
      </p>
      <ul>
        <li>Photos: gallery cards</li>
        <li>Audio: embedded player</li>
        <li>Video: YouTube/Vimeo embeds or local clips</li>
      </ul>
      <a href={base}>Back home</a> · <a href={href('papers/')}>Papers</a>
    </main>
  </body>
</html>
