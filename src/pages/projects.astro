---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const base = import.meta.env.BASE_URL;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || "G-QWP2XJ4VMK";

const resolveLink = (url = '') => String(url || '');

const categoryOrder = ['Machine Learning', 'Visualization & Dashboard'];
const grouped = projects.reduce((acc, p) => {
  const category = p.data.category || 'Other';
  if (!acc[category]) acc[category] = [];
  acc[category].push(p);
  return acc;
}, {});

const orderedCategories = [
  ...categoryOrder.filter((c) => grouped[c]?.length),
  ...Object.keys(grouped).filter((c) => !categoryOrder.includes(c)).sort(),
];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Projects</title>
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline>
          {`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${gaId}');`}
        </script>
      </>
    )}
  </head>
  <body>
    <main class="container">
      <h1>Projects</h1>

      {orderedCategories.map((category) => (
        <section>
          <h2>{category}</h2>
          <ul>
            {grouped[category].map((p) => (
              <li>
                <strong>{p.data.title}</strong> — {p.data.summary}
                {p.data.links?.repo && <> <a href={resolveLink(p.data.links.repo)} target="_blank" rel="noopener noreferrer">Repo</a></>}
                {p.data.links?.demo && <> · <a href={resolveLink(p.data.links.demo)} target="_blank" rel="noopener noreferrer">Link</a></>}
                {p.data.links?.report && <> · <a href={resolveLink(p.data.links.report)} target="_blank" rel="noopener noreferrer">PDF report</a></>}
              </li>
            ))}
          </ul>
        </section>
      ))}

      <a href={base}>Back home</a> · <a href={`${base}papers/`}>Papers</a>
    </main>
  </body>
</html>
