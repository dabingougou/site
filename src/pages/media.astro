---
import '../styles/global.css';
const base = import.meta.env.BASE_URL;
const basePrefix = base.endsWith('/') ? base : base + '/';
const href = (path = '') => basePrefix + String(path).replace(/^\/+/, '');
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Media</title>
        <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-QWP2XJ4VMK"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-QWP2XJ4VMK');
    </script>


  </head>
  <body>
    <main class="container">
      <h1>Media</h1>
      <p>
        Placeholder for photos, audio clips, and videos.
      </p>
      <ul>
        <li>Photos: gallery cards</li>
        <li>Audio: embedded player</li>
        <li>Video: YouTube/Vimeo embeds or local clips</li>
      </ul>
      <a href={base}>Back home</a> · <a href={href('papers/')}>Papers</a>
    </main>
  </body>
</html>
